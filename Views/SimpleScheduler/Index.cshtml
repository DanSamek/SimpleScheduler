@using System.Globalization
@model SimpleScheduler.Views.SimpleScheduler.Index;

@{
    Layout = null;
}

<!DOCTYPE html> 
<html>
<head>
    <script src="~/js/signalr/dist/browser/signalr.js"></script>
    <script src="~/js/simple-scheduler.js"></script>
    <title>Simple scheduler</title>
</head>
<body>
<div>
    Simple scheduler
</div>

<div class="jobs">
    @foreach (var job in Model.Jobs)
    {
        <div id="job-@job.Id">
            <span>@job.Key</span>
            <span>@job.IsRecurrent()</span>
            <span class="state">@job.State</span>
            <span>@job.ExecutionTime.ToString(CultureInfo.InvariantCulture)</span>
        </div>
    }
</div>
</body>
</html>
