@using System.Text.Json
@using SimpleScheduler
@model global::SimpleScheduler.Views.SimpleScheduler.JobModel

@{
    var job = Model.JobDto;
    var methodArgs = JsonSerializer.Serialize(job.Arguments);
    var canShowEditor = methodArgs != "[]";
    
    Layout = "_Layout";
    ViewData["Title"] = $"{job.Type}.{job.MethodName}";
}

<div class="grid">
    <div class="container">
        <p>Key: @job.Key</p>
        <p>Type: @job.Type</p>
        <p>Method name: @job.MethodName</p>
        <p>Next execution time: @job.NextExecutionTime</p>
        <p>Recurrent: @job.IsRecurrent</p>
    </div>

    <div class="container is-flex is-flex-direction-column" style="gap: 1em">
        @if (canShowEditor)
        {
            <div>Arguments</div>
            <div class="job-arguments" style="height: 100px; width: 100%"></div>
        }
        <div class="is-flex is-flex-direction-column is-align-items-end" style="gap: 0.5em;">
            @if (canShowEditor)
            {
                <p><i>NOTE: this will create new job entity</i></p>
            }
            <button class="button" onclick="schedule(@job.Id, getEditorValue())">Schedule job</button>
        </div>
    </div>
</div>

<p>Last executions (max @(Constants.PAGE_SIZE))</p>

@{
    await Html.RenderPartialAsync("_ExecutionsTable", Model.JobDto.Executions);
}

@if (canShowEditor)
{
    <script>
    let editor;
    require.config({ paths: { 'vs': '/js/min/vs' }});
    require(['vs/editor/editor.main'], function() {
        editor = monaco.editor.create(document.querySelector(".job-arguments"),{
            value: '@Html.Raw(methodArgs)',
            language: 'json',
            automaticLayout: true,
            theme: 'vs-dark',
            readOnly: false
        });
    });
    
    function getEditorValue() {
        return editor.getValue();
    }
</script>
    
}
